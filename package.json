{
  "name": "google-ai-election-assistant",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend/web",
    "backend/api"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w frontend/web\" \"npm run dev -w backend/api\"",
    "build": "npm run build --workspaces",
    "start": "npm run start --workspaces",
    "lint": "npm run lint --workspaces"
  },
  "dependencies": {
    "concurrently": "^9.2.1"
  }
}
